// This file is generated by prisma/scripts/build-schema.cjs.
// Edit the source files in prisma/schema-parts/ instead of editing this file directly.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & PREFERENCES
// ============================================================================

enum UserRole {
  ADMIN
  MODERATOR
  USER
  PREMIUM_USER
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  avatar   String?
  password String
  bio      String?

  isActive      Boolean @default(true)
  isBanned      Boolean @default(false)
  emailVerified Boolean @default(false)

  role UserRole @default(USER)

  totalMoods        Int @default(0)
  totalSessions     Int @default(0)
  totalAchievements Int @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime?

  preferences            UserPreferences?
  subscription           Subscription?
  moods                  Mood[]
  breakSessions          BreakSession[]
  journals               Journal[]
  meditations            MeditationSession[]
  reminders              Reminder[]
  notifications          Notification[]
  achievements           UserAchievement[]
  badges                 UserBadge[]
  streak                 UserStreak?
  points                 UserPoints?
  userLevel              UserLevel?
  friends                Friend[]           @relation("UserFriends")
  friendRequestsReceived Friend[]           @relation("FriendRequests")
  challenges             UserChallenge[]
  leaderboardEntries     LeaderboardEntry[]
  feedEntries            FeedEntry[]
  feedback               Feedback[]
  contentRatings         ContentRating[]
  payments               Payment[]
  integrations           IntegrationLink[]
  aiInsights             AIInsight[]
  analytics              Analytics[]
  insights               Insight[]
  recommendations        Recommendation[]
  storageFiles           StorageFile[]
  sessions               Session[]
  events                 Event[]
  rateLimitCounters      RateLimitCounter[]
  adminLogs              AdminLog[]         @relation("AdminActorLogs")

  @@index([email])
  @@index([role])
  @@map("users")
}

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  pushNotificationsEnabled  Boolean @default(true)
  emailNotificationsEnabled Boolean @default(true)
  smsNotificationsEnabled   Boolean @default(false)
  inAppNotificationsEnabled Boolean @default(true)

  dailyBreakGoal Int    @default(4)
  breakDuration  Int    @default(15)
  breakMode      String @default("POMODORO")

  preferredExerciseDuration Int    @default(20)
  exerciseFrequency         String @default("DAILY")

  profilePrivacy         String  @default("PUBLIC")
  showStatsInLeaderboard Boolean @default(true)
  allowFriendRequests    Boolean @default(true)

  timezone String @default("UTC")
  language String @default("en")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("user_preferences")
}

// ============================================================================
// SUBSCRIPTIONS & BILLING TIERS
// ============================================================================

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  PENDING
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

model SubscriptionTier {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  price        Float
  billingCycle BillingCycle

  features      TierFeature[]
  limits        TierLimit[]
  subscriptions Subscription[]

  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscription_tiers")
}

model TierFeature {
  id     String           @id @default(cuid())
  tierId String
  tier   SubscriptionTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  name        String
  included    Boolean @default(true)
  description String?

  createdAt DateTime @default(now())

  @@unique([tierId, name])
  @@index([tierId])
  @@map("tier_features")
}

model TierLimit {
  id     String           @id @default(cuid())
  tierId String
  tier   SubscriptionTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  name  String
  value Int
  unit  String?

  createdAt DateTime @default(now())

  @@unique([tierId, name])
  @@index([tierId])
  @@map("tier_limits")
}

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tierId String
  tier   SubscriptionTier @relation(fields: [tierId], references: [id])

  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime?
  renewalDate DateTime?

  stripeSubscriptionId String?
  paypalSubscriptionId String?

  autoRenew Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tierId])
  @@map("subscriptions")
}

// ============================================================================
// WELLNESS: MOODS, BREAKS, JOURNALS, MEDITATION
// ============================================================================

enum MoodType {
  HAPPY
  SAD
  ANXIOUS
  CALM
  FRUSTRATED
  ENERGIZED
  TIRED
  EXCITED
  NEUTRAL
  STRESSED
}

enum BreakMode {
  POMODORO
  SHORT_BREAK
  LONG_BREAK
  CUSTOM
}

model Mood {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       MoodType
  intensity  Int
  notes      String?
  tags       String[]
  activities String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("moods")
}

model BreakSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mode            BreakMode @default(POMODORO)
  duration        Int
  plannedDuration Int
  status          String    @default("COMPLETED")

  startedAt   DateTime
  endedAt     DateTime?
  completedAt DateTime?

  notes      String?
  activities String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("break_sessions")
}

model Journal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  content String   @db.Text
  mood    MoodType?
  tags    String[]

  isPrivate  Boolean @default(true)
  isFavorite Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("journals")
}

model BreathingExercise {
  id          String @id @default(cuid())
  title       String
  description String?

  inhaleCount Int
  holdCount   Int
  exhaleCount Int
  cycles      Int
  duration    Int
  difficulty  String @default("BEGINNER")

  audioUrl  String?
  imageUrl  String?
  createdBy String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("breathing_exercises")
}

model MeditationSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  guideId String?
  guide   MeditationGuide? @relation(fields: [guideId], references: [id], onDelete: SetNull)

  duration  Int
  startedAt DateTime
  endedAt   DateTime?

  focusArea String?
  mood      MoodType?
  quality   Int?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("meditation_sessions")
}

model MeditationGuide {
  id          String @id @default(cuid())
  title       String
  description String?

  duration   Int
  focusArea  String
  difficulty String @default("BEGINNER")

  audioUrl   String?
  imageUrl   String?
  instructor String?

  isActive  Boolean             @default(true)
  sessions  MeditationSession[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@map("meditation_guides")
}

model Reminder {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  message String?
  type    String @default("BREAK")

  scheduledTime DateTime
  frequency     String?
  isActive      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([scheduledTime])
  @@map("reminders")
}

enum NotificationType {
  PUSH
  EMAIL
  SMS
  IN_APP
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  message String
  type    NotificationType

  relatedEntity String?
  relatedId     String?

  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ============================================================================
// ENGAGEMENT: GAMIFICATION, SOCIAL, FEED
// ============================================================================

enum AchievementType {
  MOOD_STREAK
  SESSION_MILESTONE
  CONSISTENCY
  EXPLORATION
  SOCIAL
  WELLNESS
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model Achievement {
  id          String @id @default(cuid())
  title       String
  description String?

  type   AchievementType
  icon   String?
  points Int @default(10)

  condition String
  isActive  Boolean @default(true)

  userAchievements UserAchievement[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("achievements")
}

model UserAchievement {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  unlockedAt DateTime @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model Badge {
  id          String @id @default(cuid())
  title       String
  description String?
  icon        String?

  category String
  rarity   String  @default("COMMON")
  isActive Boolean @default(true)

  userBadges UserBadge[]
  createdAt  DateTime    @default(now())

  @@map("badges")
}

model UserBadge {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model UserStreak {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  currentStreak    Int @default(0)
  longestStreak    Int @default(0)
  streakType       String   @default("MOOD_TRACKING")
  lastActivityDate DateTime?
  startDate        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("user_streaks")
}

model UserPoints {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalPoints   Int @default(0)
  pointsHistory PointsTransaction[]
  updatedAt     DateTime            @updatedAt

  @@map("user_points")
}

model PointsTransaction {
  id           String @id @default(cuid())
  userPointsId String
  userPoints   UserPoints @relation(fields: [userPointsId], references: [id], onDelete: Cascade)

  amount    Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userPointsId])
  @@map("points_transactions")
}

model UserLevel {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  level        Int @default(1)
  experience   Int @default(0)
  nextLevelExp Int @default(1000)
  updatedAt    DateTime @updatedAt

  @@map("user_levels")
}

model Friend {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)

  friendId String
  friend   User   @relation("FriendRequests", fields: [friendId], references: [id], onDelete: Cascade)

  status      FriendRequestStatus @default(PENDING)
  requestedAt DateTime            @default(now())
  respondedAt DateTime?

  @@unique([userId, friendId])
  @@index([userId])
  @@index([status])
  @@map("friends")
}

model Challenge {
  id          String @id @default(cuid())
  title       String
  description String?

  type         String
  difficulty   String @default("MEDIUM")
  durationDays Int
  goal         Int
  reward       Int
  createdBy    String?
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean @default(true)

  createdAt      DateTime        @default(now())
  userChallenges UserChallenge[]

  @@map("challenges")
}

model UserChallenge {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  progress    Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?
  joinedAt    DateTime @default(now())

  @@unique([userId, challengeId])
  @@index([userId])
  @@map("user_challenges")
}

model LeaderboardEntry {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rank      Int
  score     Int
  period    String   @default("WEEKLY")
  updatedAt DateTime @updatedAt

  @@unique([userId, period])
  @@index([rank])
  @@index([period])
  @@map("leaderboard_entries")
}

model FeedEntry {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String
  title       String
  description String?
  relatedId   String?
  visibility  String   @default("PUBLIC")
  likes       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("feed_entries")
}

// ============================================================================
// CONTENT, FEEDBACK, INSIGHTS, RECOMMENDATIONS
// ============================================================================

model Sound {
  id          String @id @default(cuid())
  title       String
  description String?

  category  String
  duration  Int
  audioUrl  String
  imageUrl  String?
  createdBy String?

  isActive  Boolean  @default(true)
  rating    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("sounds")
}

model Quote {
  id       String @id @default(cuid())
  text     String @db.Text
  author   String?
  category String?
  source   String?
  imageUrl String?

  isActive  Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quotes")
}

model Feedback {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String
  subject   String
  message   String @db.Text
  status    String @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("feedback")
}

model ContentRating {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contentType String
  contentId   String
  rating      Int
  review      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, contentType, contentId])
  @@index([contentType])
  @@map("content_ratings")
}

model Analytics {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date             DateTime
  moodCount        Int      @default(0)
  avgMoodIntensity Float    @default(0)
  topMood          String?
  sessionCount     Int      @default(0)
  totalSessionTime Int      @default(0)
  meditationCount  Int      @default(0)
  journalCount     Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("analytics")
}

model Insight {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       String
  title      String
  content    String @db.Text
  confidence Float
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("insights")
}

model AIInsight {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       String
  title      String
  content    String @db.Text
  aiProvider String
  isUseful   Boolean?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("ai_insights")
}

model Recommendation {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contentType String
  contentId   String
  reason      String
  score       Float
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("recommendations")
}

// ============================================================================
// PLATFORM: PAYMENTS, STORAGE, SECURITY, OPERATIONS
// ============================================================================

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  PAYPAL
  CREDIT_CARD
  DEBIT_CARD
}

enum EventType {
  MOOD_CREATED
  SESSION_STARTED
  SESSION_COMPLETED
  ACHIEVEMENT_UNLOCKED
  BADGE_EARNED
  STREAK_UPDATED
  FRIEND_ADDED
  CHALLENGE_JOINED
  CHALLENGE_COMPLETED
}

model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount          Float
  currency        String @default("USD")
  status          PaymentStatus @default(PENDING)
  method          PaymentMethod
  description     String?
  stripePaymentId String?
  paypalPaymentId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("payments")
}

model IntegrationLink {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type String

  isActive       Boolean @default(true)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@map("integration_links")
}

model StorageFile {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  filename  String
  mimetype  String
  size      Int
  provider  String
  url       String
  publicUrl String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("storage_files")
}

model Event {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  type      EventType
  data      String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("events")
}

model AdminLog {
  id      String @id @default(cuid())
  adminId String
  admin   User   @relation("AdminActorLogs", fields: [adminId], references: [id], onDelete: Cascade)

  action     String
  targetId   String?
  targetType String?
  details    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@map("admin_logs")
}

model RateLimitCounter {
  id        String @id @default(cuid())
  userId    String?
  user      User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress String?

  endpoint String
  count    Int      @default(1)
  resetAt  DateTime

  @@unique([userId, endpoint])
  @@unique([ipAddress, endpoint])
  @@index([resetAt])
  @@map("rate_limit_counters")
}

model SearchIndex {
  id         String @id @default(cuid())
  entityType String
  entityId   String
  title      String
  content    String   @db.Text
  tags       String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId])
  @@map("search_indices")
}

model CacheEntry {
  id        String @id @default(cuid())
  key       String @unique
  value     String @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("cache_entries")
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}
