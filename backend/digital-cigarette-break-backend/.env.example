# Copy this file to .env and adjust values for your environment.
#
# DATABASE_URL must match backend/docker-compose.yml
# (Postgres 16 exposed on host port 5555).
DATABASE_URL="postgresql://postgres:123456@localhost:5555/digital_cigarette_break"

# HTTP port the NestJS app listens on.
PORT=3000

# Secret used to sign JWT access tokens. Use a long random value in production.
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Allowed CORS origin(s). Use a specific origin in production, "*" for local dev.
CORS_ORIGIN="*"
