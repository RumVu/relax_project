{
  "name": "digital-cigarette-break",
  "private": true,
  "version": "1.2.0-rc.1",
  "workspaces": [
    "apps/backend",
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm --workspace apps/backend run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm run build --workspaces --if-present",
    "build:backend": "npm --workspace apps/backend run build",
    "build:web": "npm --workspace apps/web run build",
    "prisma:generate": "npm --workspace apps/backend run prisma:generate",
    "prisma:migrate:deploy": "npm --workspace apps/backend run prisma:migrate:deploy",
    "prisma:seed": "npm --workspace apps/backend run prisma:seed",
    "storage:sync-ambient-sounds": "npm --workspace apps/backend run storage:sync-ambient-sounds --",
    "prisma:cleanup-test-data": "node apps/backend/prisma/scripts/cleanup-test-data.cjs"
  },
  "dependencies": {
    "@nestjs/platform-express": "^11.1.28",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "^25.0.1"
  },
  "overrides": {
    "postcss": "8.5.15",
    "ws": "8.21.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
