# =============================================================================
# Production environment template.
# Copy into your deployment secret store; do not commit real values.
# =============================================================================

POSTGRES_USER=relax_app
POSTGRES_PASSWORD=<strong-postgres-password>
POSTGRES_DB=digital_cigarette_break

BACKEND_PORT=6823
DATABASE_URL=postgresql://relax_app:<strong-postgres-password>@postgres:5432/digital_cigarette_break?schema=public
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true

NODE_ENV=production
LOG_LEVEL=info
TRUST_PROXY=1
CORS_ORIGINS=https://your-web-domain.example

JWT_SECRET=<openssl-rand-base64-48>
JWT_EXPIRES_IN=15m
JWT_ISSUER=digital-cigarette-break-api
JWT_AUDIENCE=digital-cigarette-break-app

# HttpOnly refresh cookie. Use SameSite=None only with Secure=true.
AUTH_REFRESH_COOKIE_NAME=relax_refresh_token
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAME_SITE=none

# Production docs: either disable Swagger or protect it with Basic auth.
SWAGGER_ENABLED=false
SWAGGER_PUBLIC=false
SWAGGER_BASIC_USER=
SWAGGER_BASIC_PASSWORD=

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=public-assets

GOOGLE_CLIENT_ID=627379199532-4o73eb98p9s6l70dav8s4l8qujja1ljr.apps.googleusercontent.com

NEXT_PUBLIC_API_URL=https://your-api-domain.example
NEXT_PUBLIC_GOOGLE_CLIENT_ID=627379199532-4o73eb98p9s6l70dav8s4l8qujja1ljr.apps.googleusercontent.com
