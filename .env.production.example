# =============================================================================
# Production environment template.
# Copy into your deployment secret store; do not commit real values.
# =============================================================================

POSTGRES_USER=relax_app
POSTGRES_PASSWORD=<strong-postgres-password>
POSTGRES_DB=digital_cigarette_break

BACKEND_PORT=6823
DATABASE_URL=postgresql://relax_app:<strong-postgres-password>@postgres:5432/digital_cigarette_break?schema=public
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true

NODE_ENV=production
LOG_LEVEL=info
TRUST_PROXY=1
CORS_ORIGINS=https://your-web-domain.example
# Disabling auto-migration on startup in production prevents race conditions
# when scaling multiple replicas. Run it as a separate deployment step instead:
#   npm --workspace apps/backend run prisma:migrate:deploy
RUN_MIGRATIONS_ON_START=false

JWT_SECRET=<openssl-rand-base64-48>
JWT_EXPIRES_IN=15m
JWT_ISSUER=digital-cigarette-break-api
JWT_AUDIENCE=digital-cigarette-break-app

# HttpOnly refresh cookie. Use SameSite=None only with Secure=true.
AUTH_REFRESH_COOKIE_NAME=relax_refresh_token
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAME_SITE=none

# Production docs: either disable Swagger or protect it with Basic auth.
SWAGGER_ENABLED=false
SWAGGER_PUBLIC=false
SWAGGER_BASIC_USER=
SWAGGER_BASIC_PASSWORD=

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=public-assets

GOOGLE_CLIENT_ID=<your-google-client-id-web>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REDIRECT_URI=https://your-domain.example/auth/google/callback

# Email verification/reset provider. Pick one real provider in production.
EMAIL_PROVIDER=none
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_URL=

# Push notification providers. Device registration works without these,
# but real delivery requires at least one configured provider.
FCM_SERVER_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=
EXPO_ACCESS_TOKEN=

# Billing providers. Manual/dev checkout works without these; external
# provider sessions require real keys.
STRIPE_SECRET_KEY=
APPLE_SHARED_SECRET=
APP_STORE_CONNECT_API_KEY=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

NEXT_PUBLIC_API_URL=https://your-api-domain.example
NEXT_PUBLIC_GOOGLE_CLIENT_ID=<your-google-client-id-web>.apps.googleusercontent.com
