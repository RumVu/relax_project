# =============================================================================
# Digital Cigarette Break — root environment template
# Copy to `.env` (gitignored). Per-app overrides live in `apps/<app>/.env`.
# Used by docker-compose to wire backend ↔ web ↔ infrastructure.
# =============================================================================

# ---- Infrastructure (docker-compose) ----------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=digital_cigarette_break
POSTGRES_PORT=5555

REDIS_PORT=6379

# ---- Backend (apps/backend) — see apps/backend/.env.example for full list ---
BACKEND_PORT=6823
DATABASE_URL=postgresql://postgres:123456@localhost:5555/digital_cigarette_break?schema=public
REDIS_URL=redis://localhost:6379

# CORS allow-list. Mặc định gồm:
#   - localhost dev/web (3000/3233)
#   - Vercel production web đã deploy
# Khi a `make share-vercel` script sẽ tự bồi thêm URL tunnel + Vercel.
CORS_ORIGINS=http://localhost:3000,http://localhost:3233,https://relax-project-web-dashboard.vercel.app

# JWT — sinh 1 lần: openssl rand -hex 32
JWT_SECRET=replace-me-please-with-openssl-rand-hex-32

# Refresh token cookie. Keep Secure=false for local http; set Secure=true and
# SameSite=None when frontend/backend live on different HTTPS domains.
AUTH_REFRESH_COOKIE_NAME=relax_refresh_token
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=lax

# Swagger docs. Public docs are convenient locally but should stay false on
# deployed/prod environments unless the API is intentionally public.
SWAGGER_ENABLED=true
SWAGGER_PUBLIC=false
SWAGGER_BASIC_USER=
SWAGGER_BASIC_PASSWORD=

# Google Sign-In — Client ID public, có thể commit.
# Client Secret chỉ để backend dùng authorization-code flow.
GOOGLE_CLIENT_ID=884741112800-aq6rsskn13eiv1r3f3e5qbttlj82skcs.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://relax-project-web-dashboard.vercel.app/auth/google/callback

# ---- Web (apps/web) ---------------------------------------------------------
WEB_PORT=3233
# Local dev / docker LAN dùng http://localhost:6823 (hoặc http://<LAN-IP>:6823).
# Khi frontend chạy trên Vercel: set Vercel env NEXT_PUBLIC_API_URL = URL tunnel
# (vd https://abc-def.trycloudflare.com) — KHÔNG nhét tunnel URL vào file này.
NEXT_PUBLIC_API_URL=http://localhost:6823
NEXT_PUBLIC_GOOGLE_CLIENT_ID=884741112800-aq6rsskn13eiv1r3f3e5qbttlj82skcs.apps.googleusercontent.com
