# ──────────────────────────────────────────────────────────────────
# Relax mobile — biến môi trường build-time
# ──────────────────────────────────────────────────────────────────
# Cách dùng: copy file này thành .env, điền giá trị, rồi build bằng:
#
#   flutter run \
#     --dart-define=RELAX_API_URL=https://api.relax.dev/v1 \
#     --dart-define=SUPABASE_URL=https://xyz.supabase.co \
#     --dart-define=SUPABASE_ANON_KEY=eyJxxx... \
#     --dart-define=SEPAY_RETURN_URL=https://app.relax.dev/billing \
#     --dart-define=APP_FLAVOR=prod
#
# Hoặc dùng `--dart-define-from-file=.env` (Flutter 3.16+) để load 1 phát.
#
# Các biến này được đọc trong `lib/config/env.dart` qua `String.fromEnvironment`.
# KHÔNG commit file .env thật — đã .gitignore.

# Backend Nest URL — KHÔNG kèm trailing slash.
# Khi chạy local + máy thật, dùng Tailscale Funnel cho HTTPS hợp lệ.
RELAX_API_URL=https://relax-backend.tail3e0c74.ts.net/v1

# Supabase project URL (cùng project với backend Storage).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon (public) key — chỉ dùng cho client read & upload qua bucket
# public hoặc signed-url. KHÔNG bao giờ paste service_role key vào client.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PLACEHOLDER

# SePay redirect khi checkout xong (success/cancel/error trả về URL này).
SEPAY_RETURN_URL=https://app.relax.dev/billing

# Tên build: dev / staging / prod — em đọc để log + bật/tắt banner debug.
APP_FLAVOR=dev
