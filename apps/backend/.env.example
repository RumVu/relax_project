# Local backend defaults. Copy this file to apps/backend/.env before running the API.
NODE_ENV="development"
PORT="6823"
DATABASE_URL="postgresql://postgres:123456@localhost:5555/digital_cigarette_break?schema=public"

# Auth
JWT_SECRET="change-me-local-jwt-secret"
JWT_EXPIRES_IN="7d"

# Supabase Storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
SUPABASE_SECRET_KEY="your-supabase-secret-key"
SUPABASE_BUCKET="public-assets"

# Weekly stats materialization job
WEEKLY_STATS_JOB_ENABLED="false"
WEEKLY_STATS_JOB_INTERVAL_MS="21600000"
WEEKLY_STATS_JOB_BATCH_SIZE="500"

# Email providers. Leave blank for local dev; auth will return dev tokens.
EMAIL_PROVIDER="none"
RESEND_API_KEY=""
SENDGRID_API_KEY=""
SMTP_URL=""
EMAIL_VERIFICATION_TTL_MS="86400000"
PASSWORD_RESET_TTL_MS="1800000"

# Push providers. Leave blank until mobile push is connected.
FCM_SERVER_KEY=""
FIREBASE_SERVICE_ACCOUNT_JSON=""
APNS_KEY_ID=""
APNS_TEAM_ID=""
APNS_BUNDLE_ID=""
APNS_PRIVATE_KEY=""
EXPO_ACCESS_TOKEN=""

# Billing providers. Leave blank until production payment flow is connected.
STRIPE_SECRET_KEY=""
APPLE_SHARED_SECRET=""
APP_STORE_CONNECT_API_KEY=""
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=""
