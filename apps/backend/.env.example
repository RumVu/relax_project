# =============================================================================
# Backend (NestJS) — environment template
# Copy to apps/backend/.env (gitignored) and fill in real values.
# =============================================================================

# ---- Server ----------------------------------------------------------------
PORT=6823
NODE_ENV=development
LOG_LEVEL=info
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:3000,http://localhost:3233,http://localhost:5300,http://localhost:6823,https://relax-project-web-dashboard.vercel.app

# ---- Database (Postgres via Prisma) ----------------------------------------
DATABASE_URL=postgresql://postgres:123456@localhost:5555/digital_cigarette_break?schema=public

# ---- Auth / JWT ------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-strong-random-secret
JWT_EXPIRES_IN=15m
JWT_ISSUER=digital-cigarette-break-api
JWT_AUDIENCE=digital-cigarette-break-app
AUTH_REFRESH_COOKIE_NAME=relax_refresh_token
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=lax

# ---- Supabase Storage ------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_BUCKET=public-assets

# ---- Redis (optional — set REDIS_ENABLED=false to disable) -----------------
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=dcb:
REDIS_DEFAULT_TTL_SECONDS=300

# ---- BullMQ queues (optional) ----------------------------------------------
QUEUE_ENABLED=true
QUEUE_PREFIX=dcb-queue
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=5000

# ---- Google sign-in --------------------------------------------------------
# OAuth 2.0 Client IDs. You can specify individual Client IDs per environment
# or use the comma-separated GOOGLE_CLIENT_ID fallback.
# Android Client: 884741112800-vkq8svs2c4012n457uta7uva4n4mteii.apps.googleusercontent.com
# iOS Client:     884741112800-d02cdshsm4bh34qgrlcmp70r1h2o5lp5.apps.googleusercontent.com
# Web Client:     884741112800-aq6rsskn13eiv1r3f3e5qbttlj82skcs.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=884741112800-vkq8svs2c4012n457uta7uva4n4mteii.apps.googleusercontent.com
GOOGLE_CLIENT_ID_IOS=884741112800-d02cdshsm4bh34qgrlcmp70r1h2o5lp5.apps.googleusercontent.com
GOOGLE_CLIENT_ID_WEB=884741112800-aq6rsskn13eiv1r3f3e5qbttlj82skcs.apps.googleusercontent.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://relax-project-web-dashboard.vercel.app/auth/google/callback

# ---- Swagger (optional basic auth in production) ---------------------------
SWAGGER_ENABLED=true
SWAGGER_PUBLIC=false
SWAGGER_BASIC_USER=
SWAGGER_BASIC_PASSWORD=

# ---- SePay Integration -----------------------------------------------------
SEPAY_MERCHANT_ID=SP-TEST-VN95276B
SEPAY_SECRET_KEY=spsk_test_PGD3VPwwsGfAiTKSCiEDEE3LapHHiQPE
SEPAY_ENV=sandbox
SEPAY_WEBHOOK_API_KEY=your-sepay-webhook-api-key

# ---- Admin Bank Details for VietQR/SePay ----
ADMIN_BANK_ID=MB
ADMIN_BANK_ACCOUNT=0969966969
ADMIN_BANK_NAME="MB Bank"
ADMIN_BANK_HOLDER="NGUYEN VAN A"


# ---- Email (verify-email + reset-password) ---------------------------------
# Provider auto-detected from the first key present. EMAIL_PROVIDER overrides.
# When nothing is set, the `log` provider writes to the application log and the
# token is surfaced in the API response (`devToken`) so dev flows still work.
EMAIL_PROVIDER=          # resend | smtp | sendgrid | log (default: auto)
EMAIL_FROM=Relax <noreply@relax.local>
APP_BASE_URL=https://relax-project-web-dashboard.vercel.app
# Resend
RESEND_API_KEY=
# Nodemailer-compatible SMTP URL: smtp://user:pass@host:port (use smtps:// for TLS)
SMTP_URL=
# SendGrid
SENDGRID_API_KEY=
# TTLs (defaults: 24h verify, 30m reset)
EMAIL_VERIFICATION_TTL_MS=
PASSWORD_RESET_TTL_MS=

# ---- AI / Gemini -----------------------------------------------------------
# Used by AiInsightsService and Companion Chat.
# When unset, both fall back to deterministic heuristic providers.
# Option 1: Vertex AI (uses Google Cloud credits)
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
# Option 2: API key (AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
