# =============================================================================
# Backend (NestJS) — environment template
# Copy to apps/backend/.env (gitignored) and fill in real values.
# =============================================================================

# ---- Server ----------------------------------------------------------------
PORT=6823
NODE_ENV=development
LOG_LEVEL=info
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:3000,http://localhost:3233,http://localhost:5300,http://localhost:6823,https://relax-project-web-dashboard.vercel.app

# ---- Database (Postgres via Prisma) ----------------------------------------
DATABASE_URL=postgresql://postgres:123456@localhost:5555/digital_cigarette_break?schema=public

# ---- Auth / JWT ------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-strong-random-secret
JWT_EXPIRES_IN=15m
JWT_ISSUER=digital-cigarette-break-api
JWT_AUDIENCE=digital-cigarette-break-app

# ---- Supabase Storage ------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_BUCKET=public-assets

# ---- Redis (optional — set REDIS_ENABLED=false to disable) -----------------
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=dcb:
REDIS_DEFAULT_TTL_SECONDS=300

# ---- BullMQ queues (optional) ----------------------------------------------
QUEUE_ENABLED=true
QUEUE_PREFIX=dcb-queue
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=5000

# ---- Google sign-in --------------------------------------------------------
# OAuth 2.0 Client ID(s) từ Google Cloud Console → APIs & Services →
# Credentials → "OAuth client ID".
#
# 1 project Google thường có nhiều client per platform:
#   - Web application       → cho dashboard (Vercel)
#   - iOS                   → cho mobile app
#   - Android               → cho mobile app
#
# Backend verify ID token → check `aud` của token phải khớp 1 trong list.
# Hỗ trợ multi: ngăn cách bằng dấu phẩy.
#
# Web Client: Authorized JavaScript origin phải include localhost:3233 (dev)
# + production URL.
# iOS Client: chỉ cần Bundle ID = com.example.relaxApp.
# Android Client: Package name + SHA-1 fingerprint của keystore.
#
# NEXT_PUBLIC_GOOGLE_CLIENT_ID (web) phải khớp 1 trong list này.
# Mobile app build với --dart-define=GOOGLE_CLIENT_ID=<iOS hoặc Android client>.
# Đây là Client ID PUBLIC, có thể commit. Secret KHÔNG dùng cho ID Token flow.
GOOGLE_CLIENT_ID=627379199532-4o73eb98p9s6l70dav8s4l8qujja1ljr.apps.googleusercontent.com

# ---- Swagger (optional basic auth in production) ---------------------------
SWAGGER_ENABLED=true
SWAGGER_PUBLIC=true
SWAGGER_BASIC_USER=
SWAGGER_BASIC_PASSWORD=
