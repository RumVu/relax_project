{
  "name": "digital-cigarette-break-backend",
  "version": "1.2.0-rc.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "node ./scripts/free-dev-port.cjs && nest start --watch",
    "dev:fresh": "npm run dev",
    "port:free": "node ./scripts/free-dev-port.cjs",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "postinstall": "npm run prisma:generate",
    "prisma:sync-schema": "node ./prisma/scripts/build-schema.cjs",
    "prisma:db:push": "npm run prisma:sync-schema && prisma db push",
    "prisma:generate": "npm run prisma:sync-schema && DATABASE_URL=${DATABASE_URL:-postgresql://postgres:123456@localhost:5555/digital_cigarette_break?schema=public} prisma generate",
    "prisma:migrate:dev": "npm run prisma:sync-schema && prisma migrate dev",
    "prisma:migrate:deploy": "npm run prisma:sync-schema && prisma migrate deploy",
    "prisma:seed": "npm run prisma:sync-schema && node ./prisma/seed.cjs",
    "storage:sync-ambient-sounds": "node ./prisma/scripts/sync-ambient-sounds-to-supabase.cjs",
    "prisma:cleanup-test-data": "node ./prisma/scripts/cleanup-test-data.cjs",
    "prisma:studio": "npm run prisma:sync-schema && prisma studio",
    "prisma:validate": "npm run prisma:sync-schema && DATABASE_URL=${DATABASE_URL:-postgresql://postgres:123456@localhost:5555/digital_cigarette_break?schema=public} prisma validate",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node scripts/start-prod.cjs",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "DATABASE_URL=${DATABASE_URL_TEST:-postgresql://postgres:123456@localhost:5555/digital_cigarette_break_test?schema=public} npm run prisma:migrate:deploy && DATABASE_URL=${DATABASE_URL_TEST:-postgresql://postgres:123456@localhost:5555/digital_cigarette_break_test?schema=public} npm run prisma:seed && DATABASE_URL=${DATABASE_URL_TEST:-postgresql://postgres:123456@localhost:5555/digital_cigarette_break_test?schema=public} jest --config ./test/jest-e2e.json --runInBand"
  },
  "dependencies": {
    "@digital-cigarette-break/shared-types": "*",
    "@digital-cigarette-break/shared-utils": "*",
    "@google/genai": "^2.10.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.21",
    "@prisma/client": "^6.19.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.105.4",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sepay-pg-node": "^1.0.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
