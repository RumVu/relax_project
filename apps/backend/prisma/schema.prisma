// This file is generated by prisma/scripts/build-schema.cjs.
// Edit the source files in prisma/schema-parts/ instead of editing this file directly.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTH
// ============================================================================

enum UserRole {
  ADMIN
  USER
}

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
}

enum ThemeMode {
  LIGHT
  DARK
  SYSTEM
}

enum AccountTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum PushPlatform {
  IOS
  ANDROID
  WEB
}

enum PushProvider {
  FCM
  APNS
  EXPO
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  avatar   String?
  password String?

  role          UserRole     @default(USER)
  authProvider  AuthProvider @default(LOCAL)
  emailVerified Boolean      @default(false)
  isActive      Boolean      @default(true)

  lastLoginAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile               UserProfile?
  preferences           UserPreference?
  companion             UserCompanion?
  sessions              Session[]
  moodCheckins          MoodCheckin[]
  weeklyMoodStats       WeeklyMoodStat[]
  userAchievements      UserAchievement[]
  userBadges            UserBadge[]
  userStreak            UserStreak?
  userPoints            UserPoints?
  userLevel             UserLevel?
  friends               Friend[]                 @relation("UserFriends")
  friendRequestsReceived Friend[]                @relation("FriendRequests")
  userChallenges        UserChallenge[]
  leaderboardEntries    LeaderboardEntry[]
  feedEntries           FeedEntry[]
  journals              Journal[]
  meditationSessions    MeditationSession[]
  companionInteractions CompanionInteraction[]
  favoriteMessages      FavoriteCompanionMessage[]
  reminders             Reminder[]
  notifications         Notification[]
  relaxSessions         RelaxSession[]
  soundSessions         SoundSession[]
  breathingSessions     BreathingSession[]
  sleepSessions         SleepSession[]
  subscriptions         Subscription[]
  payments              Payment[]
  feedbacks             Feedback[]
  contentRatings        ContentRating[]
  analyticsSnapshots    AnalyticsSnapshot[]
  integrations          IntegrationLink[]
  aiInsights            AIInsight[]
  insightCards          Insight[]
  recommendations       Recommendation[]
  storageFiles          StorageFile[]
  appEvents             AppEvent[]
  platformEvents        PlatformEvent[]
  messageLogs           CompanionMessageLog[]
  accountTokens         AccountToken[]
  pushDevices           PushDevice[]
  rateLimitCounters     RateLimitCounter[]
  adminLogs             AdminLog[]               @relation("AdminActorLogs")

  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String?
  bio         String?
  birthday    DateTime?
  zodiacSign  String?
  chineseZodiac String?

  totalMoodCheckins Int @default(0)
  totalJournalPosts Int @default(0)

  /// Denormalized profile counters for quick setup/profile rendering.
  /// Mood analytics should derive streaks from MoodCheckin/WeeklyMoodStat.
  currentStreak     Int @default(0)
  longestStreak     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

model UserPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  language String @default("vi")
  timezone String @default("Asia/Ho_Chi_Minh")
  latitude Float?
  longitude Float?
  locationName String?
  weatherEnabled Boolean @default(true)

  themeMode ThemeMode @default(SYSTEM)
  themeId   String?
  theme     AppTheme? @relation(fields: [themeId], references: [id], onDelete: SetNull)

  enableCompanionBubble   Boolean @default(true)
  bubbleIntervalSeconds   Int     @default(30)
  enableSound             Boolean @default(true)
  enableHaptics           Boolean @default(true)
  pushNotificationsEnabled  Boolean @default(true)
  emailNotificationsEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([themeId])
  @@index([timezone])
  @@map("user_preferences")
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AccountToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      AccountTokenType
  tokenHash String           @unique
  expiresAt DateTime
  consumedAt DateTime?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
  @@index([consumedAt])
  @@map("account_tokens")
}

model PushDevice {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token    String       @unique
  platform PushPlatform
  provider PushProvider @default(FCM)

  deviceId   String?
  deviceName String?
  appVersion String?
  timezone   String?
  enabled    Boolean @default(true)

  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([platform])
  @@index([provider])
  @@index([enabled])
  @@map("push_devices")
}

// ============================================================================
// COMPANION: PIXEL PET / CAT SYSTEM
// ============================================================================

enum CompanionType {
  CAT
  DOG
  RABBIT
  BIRD
  CUSTOM
}

enum CompanionMood {
  CHILL
  HAPPY
  SLEEPY
  CURIOUS
  HUNGRY
  PLAYFUL
  CALM
  SAD
}

enum CompanionAction {
  IDLE
  SLEEPING
  WALKING
  STRETCHING
  SITTING
  LOOKING
  TYPING
  PLAYING
}

enum CompanionPersonalizationMode {
  DEFAULT
  ZODIAC
  CHINESE_ZODIAC
  CUSTOM
}

enum MessageTriggerType {
  RANDOM
  TIME_BASED
  MOOD_BASED
  FIRST_OPEN
  RETURNING_USER
  LONG_SESSION
  NIGHT_TIME
  MORNING
  AFTER_CHECKIN
}

model CompanionAsset {
  id String @id @default(cuid())

  name        String
  type        CompanionType @default(CAT)
  description String?

  previewImageUrl   String?
  spriteSheetUrl    String?
  idleAnimationUrl  String?
  sleepAnimationUrl String?
  walkAnimationUrl  String?

  primaryColor   String?
  secondaryColor String?
  accentColor    String?

  zodiacSign    String?
  chineseZodiac String?

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userCompanions UserCompanion[]

  @@index([type])
  @@index([zodiacSign])
  @@index([chineseZodiac])
  @@index([isActive])
  @@map("companion_assets")
}

model UserCompanion {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  assetId String?
  asset   CompanionAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  name String @default("Mon Leo")
  type CompanionType @default(CAT)
  personalizationMode CompanionPersonalizationMode @default(DEFAULT)

  mood   CompanionMood   @default(CHILL)
  action CompanionAction @default(IDLE)

  level      Int @default(1)
  affection  Int @default(0)
  energy     Int @default(100)
  lastSeenAt DateTime?
  lastFedAt  DateTime?
  lastMoodAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  states       CompanionState[]
  interactions CompanionInteraction[]

  @@index([userId])
  @@index([assetId])
  @@map("user_companions")
}

model CompanionState {
  id          String @id @default(cuid())
  companionId String
  companion   UserCompanion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  mood      CompanionMood?
  action    CompanionAction
  animation String?
  metadata  Json?

  startedAt DateTime @default(now())
  endedAt   DateTime?

  @@index([companionId])
  @@index([startedAt])
  @@map("companion_states")
}

model CompanionMessage {
  id String @id @default(cuid())

  content String @db.Text

  triggerType   MessageTriggerType @default(RANDOM)
  mood          MoodType?
  companionMood CompanionMood?

  minHour Int?
  maxHour Int?

  weight   Int     @default(1)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites FavoriteCompanionMessage[]
  logs      CompanionMessageLog[]

  @@index([triggerType])
  @@index([mood])
  @@index([isActive])
  @@map("companion_messages")
}

model CompanionMessageLog {
  id String @id @default(cuid())

  userId    String
  messageId String

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  message CompanionMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  shownAt     DateTime @default(now())
  clickedAt   DateTime?
  dismissedAt DateTime?

  @@index([userId])
  @@index([messageId])
  @@index([shownAt])
  @@map("companion_message_logs")
}

model FavoriteCompanionMessage {
  id String @id @default(cuid())

  userId    String
  messageId String

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  message CompanionMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, messageId])
  @@index([userId])
  @@map("favorite_companion_messages")
}

model CompanionInteraction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companionId String
  companion   UserCompanion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  type     String
  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([companionId])
  @@index([createdAt])
  @@map("companion_interactions")
}

// ============================================================================
// ONBOARDING / APP CONTENT
// ============================================================================

enum MoodType {
  HAPPY
  CALM
  TIRED
  SAD
  ANXIOUS
  STRESSED
  EXCITED
  NEUTRAL
  LONELY
  GRATEFUL
}

model OnboardingSlide {
  id String @id @default(cuid())

  title       String
  subtitle    String?
  description String?

  imageUrl     String?
  animationUrl String?
  displayOrder Int @default(0)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([displayOrder])
  @@index([isActive])
  @@map("onboarding_slides")
}

model AppTheme {
  id String @id @default(cuid())

  name String @unique
  mode ThemeMode

  backgroundColor String
  surfaceColor    String
  primaryColor    String
  secondaryColor  String?
  accentColor     String?
  textColor       String
  mutedTextColor  String?

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preferences UserPreference[]

  @@index([mode])
  @@index([isActive])
  @@map("app_themes")
}

// ============================================================================
// MOOD, JOURNAL, RELAXATION
// ============================================================================

model MoodCheckin {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  mood      MoodType
  intensity Int?
  rawScore  Int?
  finalScore Int?
  scoredAt  DateTime?
  note      String? @db.Text
  tags      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([mood])
  @@index([createdAt])
  @@map("mood_checkins")
}

model WeeklyMoodStat {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekStart       DateTime
  avgScore        Float
  stressReducePct Float
  streakDays      Int
  dominantMood    MoodType?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, weekStart])
  @@index([userId])
  @@index([weekStart])
  @@map("weekly_mood_stats")
}

enum AchievementType {
  MOOD_STREAK
  SESSION_MILESTONE
  CONSISTENCY
  EXPLORATION
  SOCIAL
  WELLNESS
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

model Achievement {
  id String @id @default(cuid())

  title       String
  description String?
  type        AchievementType
  icon        String?
  points      Int             @default(10)
  condition   Json
  isActive    Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users UserAchievement[]

  @@index([type])
  @@index([isActive])
  @@map("achievements")
}

model UserAchievement {
  id String @id @default(cuid())

  userId        String
  achievementId String

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  unlockedAt DateTime @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@map("user_achievements")
}

model Badge {
  id String @id @default(cuid())

  title       String
  description String?
  icon        String?
  category    String
  rarity      String  @default("COMMON")
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users UserBadge[]

  @@index([category])
  @@index([rarity])
  @@index([isActive])
  @@map("badges")
}

model UserBadge {
  id String @id @default(cuid())

  userId  String
  badgeId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@map("user_badges")
}

/// Gamification/social streak ledger.
/// Product mood charts should use MoodCheckin-derived stats and WeeklyMoodStat.
model UserStreak {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  currentStreak    Int       @default(0)
  longestStreak     Int       @default(0)
  streakType        String    @default("MOOD_TRACKING")
  lastActivityDate  DateTime?
  startDate         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("user_streaks")
}

model UserPoints {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalPoints Int @default(0)
  updatedAt   DateTime @updatedAt

  pointsHistory PointsTransaction[]

  @@map("user_points")
}

model PointsTransaction {
  id           String     @id @default(cuid())
  userPointsId String
  userPoints   UserPoints @relation(fields: [userPointsId], references: [id], onDelete: Cascade)

  amount    Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userPointsId])
  @@map("points_transactions")
}

model UserLevel {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  level        Int      @default(1)
  experience   Int      @default(0)
  nextLevelExp Int      @default(1000)
  updatedAt    DateTime @updatedAt

  @@map("user_levels")
}

model Friend {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)

  friendId String
  friend   User   @relation("FriendRequests", fields: [friendId], references: [id], onDelete: Cascade)

  status      FriendRequestStatus @default(PENDING)
  requestedAt DateTime            @default(now())
  respondedAt DateTime?

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@index([status])
  @@map("friends")
}

model Challenge {
  id String @id @default(cuid())

  title       String
  description String?

  type         String
  difficulty   String   @default("MEDIUM")
  durationDays Int
  goal         Int
  reward       Int
  createdBy    String?
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())

  userChallenges UserChallenge[]

  @@index([type])
  @@index([isActive])
  @@map("challenges")
}

model UserChallenge {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  joinedAt    DateTime  @default(now())

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
  @@map("user_challenges")
}

model LeaderboardEntry {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rank      Int
  score     Int
  period    String   @default("WEEKLY")
  updatedAt DateTime @updatedAt

  @@unique([userId, period])
  @@index([rank])
  @@index([period])
  @@map("leaderboard_entries")
}

model FeedEntry {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String
  title       String
  description String?
  relatedId   String?
  visibility  String   @default("PUBLIC")
  likes       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("feed_entries")
}

model Journal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String?
  content String @db.Text

  mood MoodType?
  tags String[]

  isPrivate  Boolean @default(true)
  isFavorite Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([mood])
  @@map("journals")
}

model AmbientSound {
  id String @id @default(cuid())

  title       String
  description String?

  category String
  soundUrl String
  imageUrl String?
  duration Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions SoundSession[]

  @@index([category])
  @@index([isActive])
  @@map("ambient_sounds")
}

model SoundSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  soundId String?
  sound   AmbientSound? @relation(fields: [soundId], references: [id], onDelete: SetNull)

  startedAt DateTime @default(now())
  endedAt   DateTime?
  duration  Int?

  @@index([userId])
  @@index([soundId])
  @@index([startedAt])
  @@map("sound_sessions")
}

model BreathingExercise {
  id String @id @default(cuid())

  title       String
  description String?

  inhaleSeconds Int
  holdSeconds   Int
  exhaleSeconds Int
  cycles        Int
  duration      Int?

  imageUrl String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions BreathingSession[]

  @@index([isActive])
  @@map("breathing_exercises")
}

model BreathingSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  exerciseId String?
  exercise   BreathingExercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)

  startedAt DateTime @default(now())
  endedAt   DateTime?
  duration  Int?

  moodBefore MoodType?
  moodAfter  MoodType?

  @@index([userId])
  @@index([exerciseId])
  @@index([startedAt])
  @@map("breathing_sessions")
}

/// Dedicated meditation content reserved for the meditation contract.
/// The general relax flow should use RelaxActivity/RelaxSession first.
model MeditationGuide {
  id String @id @default(cuid())

  title       String
  description String?

  duration   Int
  focusArea  String
  difficulty String @default("BEGINNER")

  audioUrl   String?
  imageUrl   String?
  instructor String?
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions MeditationSession[]

  @@index([focusArea])
  @@index([isActive])
  @@map("meditation_guides")
}

/// Meditation-specific history kept for a future focused meditation screen.
/// Do not use this as the generic relax activity session table.
model MeditationSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  guideId String?
  guide   MeditationGuide? @relation(fields: [guideId], references: [id], onDelete: SetNull)

  duration  Int
  startedAt DateTime
  endedAt   DateTime?

  focusArea String?
  mood      MoodType?
  quality   Int?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([guideId])
  @@index([startedAt])
  @@map("meditation_sessions")
}

enum RelaxActivityType {
  MUSIC
  PODCAST
  JOURNAL
  BREATHING
  MYSTERY
  MEDITATION
}

enum RelaxSessionStatus {
  STARTED
  FINISHED
  CANCELLED
}

/// Canonical Play/Finish relax activity flow used by the app.
model RelaxSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activityType RelaxActivityType
  status       RelaxSessionStatus @default(STARTED)

  resourceId String?
  title      String

  startedAt DateTime @default(now())
  endedAt   DateTime?
  duration  Int?

  moodBefore MoodType?
  moodAfter  MoodType?

  reliefLevel         Int?
  stressReliefPercent Int?
  note                String? @db.Text
  nextActionAccepted  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([activityType])
  @@index([status])
  @@index([startedAt])
  @@index([endedAt])
  @@map("relax_sessions")
}

model SleepSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  startedAt DateTime
  endedAt   DateTime?

  quality Int?
  note    String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([startedAt])
  @@map("sleep_sessions")
}

model CozyQuote {
  id String @id @default(cuid())

  content String @db.Text
  author  String?
  mood    MoodType?
  imageUrl String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mood])
  @@index([isActive])
  @@map("cozy_quotes")
}

// ============================================================================
// REMINDERS & NOTIFICATIONS
// ============================================================================

enum ReminderType {
  WATER
  REST
  BREATHING
  JOURNAL
  SLEEP
  CUSTOM
}

enum NotificationType {
  IN_APP
  PUSH
  EMAIL
  SMS
}

model Reminder {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  message String?
  type    ReminderType @default(CUSTOM)

  scheduledAt DateTime
  repeatRule  String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([scheduledAt])
  @@index([isActive])
  @@map("reminders")
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  message String
  type    NotificationType @default(IN_APP)

  relatedEntity String?
  relatedId     String?

  isRead Boolean @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model ContentRating {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contentType String
  contentId   String
  rating      Int
  review      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, contentType, contentId])
  @@index([contentType])
  @@map("content_ratings")
}

model AnalyticsSnapshot {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date             DateTime
  moodCount        Int      @default(0)
  avgMoodIntensity Float    @default(0)
  topMood          String?
  sessionCount     Int      @default(0)
  totalSessionTime Int      @default(0)
  meditationCount  Int      @default(0)
  journalCount     Int      @default(0)

  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("analytics")
}

model Insight {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       String
  title      String
  content    String @db.Text
  confidence Float

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("insights")
}

model AIInsight {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       String
  title      String
  content    String @db.Text
  aiProvider String
  isUseful   Boolean?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("ai_insights")
}

model Recommendation {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contentType String
  contentId   String
  reason      String
  score       Float

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("recommendations")
}

// ============================================================================
// BILLING & PLATFORM SUPPORT
// ============================================================================

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum EventType {
  MOOD_CREATED
  SESSION_STARTED
  SESSION_COMPLETED
  ACHIEVEMENT_UNLOCKED
  BADGE_EARNED
  STREAK_UPDATED
  FRIEND_ADDED
  CHALLENGE_JOINED
  CHALLENGE_COMPLETED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

model SubscriptionTier {
  id String @id @default(cuid())

  name          String       @unique
  description   String?
  price         Float
  currency      String       @default("VND")
  billingCycle  BillingCycle
  displayOrder  Int          @default(0)
  isActive      Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  features      TierFeature[]
  limits        TierLimit[]
  subscriptions Subscription[]

  @@index([billingCycle])
  @@index([isActive])
  @@index([displayOrder])
  @@map("subscription_tiers")
}

model TierFeature {
  id String @id @default(cuid())

  tierId String
  tier   SubscriptionTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  name        String
  included    Boolean @default(true)
  description String?

  createdAt DateTime @default(now())

  @@unique([tierId, name])
  @@index([tierId])
  @@map("tier_features")
}

model TierLimit {
  id String @id @default(cuid())

  tierId String
  tier   SubscriptionTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  name  String
  value Int
  unit  String?

  createdAt DateTime @default(now())

  @@unique([tierId, name])
  @@index([tierId])
  @@map("tier_limits")
}

model Subscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tierId String?
  tier   SubscriptionTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)

  status SubscriptionStatus @default(PENDING)

  planName String @default("FREE")
  price    Float  @default(0)
  currency String @default("VND")

  startDate DateTime @default(now())
  endDate   DateTime?

  externalSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tierId])
  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount   Float
  currency String @default("VND")
  status   PaymentStatus @default(PENDING)

  provider          String?
  method            String?
  externalPaymentId String?
  stripePaymentId   String?
  paypalPaymentId   String?
  description       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("payments")
}

model IntegrationLink {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type String

  isActive       Boolean   @default(true)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@map("integration_links")
}

model Feedback {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  subject String?
  message String @db.Text
  status  String @default("OPEN")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("feedbacks")
}

model StorageFile {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  filename  String
  mimetype  String
  size      Int
  provider  String @default("supabase")
  path      String?
  url       String
  publicUrl String?
  bucket    String?
  isPublic  Boolean @default(true)
  expiresAt DateTime?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([bucket])
  @@index([expiresAt])
  @@map("storage_files")
}

/// Typed backend-emitted platform audit events.
/// Use this when the event maps to EventType.
model PlatformEvent {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  type EventType
  data Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("events")
}

model AdminLog {
  id      String @id @default(cuid())
  adminId String
  admin   User   @relation("AdminActorLogs", fields: [adminId], references: [id], onDelete: Cascade)

  action     String
  targetId   String?
  targetType String?
  details    String @db.Text

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@map("admin_logs")
}

model RateLimitCounter {
  id         String @id @default(cuid())
  identifier String
  userId     String?
  user       User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress  String?

  endpoint String
  count    Int      @default(1)
  resetAt  DateTime

  @@unique([identifier, endpoint])
  @@index([userId])
  @@index([resetAt])
  @@map("rate_limit_counters")
}

model SearchIndex {
  id         String @id @default(cuid())
  entityType String
  entityId   String
  title      String
  content    String   @db.Text
  tags       String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityType, entityId])
  @@map("search_indices")
}

model CacheEntry {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("cache_entries")
}

/// Flexible raw app/client telemetry events.
/// Promote events to PlatformEvent only after the backend contract is stable.
model AppEvent {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  type String
  data Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("app_events")
}
