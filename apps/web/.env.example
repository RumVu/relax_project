# =============================================================================
# Web (Next.js) — environment template
# Copy to apps/web/.env.local (gitignored).
# =============================================================================

# Public API base used by the dashboard and admin pages
NEXT_PUBLIC_API_URL=http://localhost:6823

# Optional Supabase public keys (only the publishable key — NEVER the secret)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Google Sign-In (Google Cloud → APIs & Services → Credentials → OAuth client)
# MUST match the GOOGLE_CLIENT_ID on the backend. Leave empty to hide
# the "Sign in with Google" button.
# Đây là Client ID PUBLIC, an toàn nhúng vào bundle frontend.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=884741112800-aq6rsskn13eiv1r3f3e5qbttlj82skcs.apps.googleusercontent.com

# Playwright base URL (defaults to http://localhost:3233 in playwright.config.ts)
# PLAYWRIGHT_BASE_URL=http://localhost:3233
