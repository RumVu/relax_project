# =============================================================================
# Web (Next.js) — environment template
# Copy to apps/web/.env.local (gitignored).
# =============================================================================

# Public API base used by the dashboard and admin pages
NEXT_PUBLIC_API_URL=http://localhost:6823

# Optional Supabase public keys (only the publishable key — NEVER the secret)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Playwright base URL (defaults to http://localhost:3233 in playwright.config.ts)
# PLAYWRIGHT_BASE_URL=http://localhost:3233
